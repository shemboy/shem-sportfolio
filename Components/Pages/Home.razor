@page "/"

<PageTitle>Shem Dualos - Portfolio</PageTitle>

<div class="hero-section py-5 mb-5 bg-light rounded shadow-sm">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-4 mb-4 mb-lg-0 text-center">
                <div class="profile-img-container shadow-lg mx-auto">
                    <img src="images/Shem.jpg" alt="Shem M. Dualos" class="profile-img" />
                </div>
            </div>
            <div class="col-lg-8 text-center text-lg-start ps-lg-5">
                <h1 class="display-3 fw-bold text-dark mb-2">Shem M. Dualos</h1>
                <h2 class="text-warning mb-4">IT Specialist & Cybersecurity Professional</h2>
                <p class="lead text-muted mb-4">
                    As a proficient IT professional, I excel in providing technical support and cybersecurity solutions. 
                    I specialize in threat hunting, incident response, and building resilient web interfaces.
                </p>
                <div class="mt-4">
                    <a href="projects" class="btn btn-warning btn-lg px-4 me-2 fw-bold">View My Work</a>
                    <a href="contact" class="btn btn-outline-dark btn-lg px-4 fw-bold">Get In Touch</a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4 text-center">
        <div class="p-4 bg-white rounded shadow-sm h-100 feature-card">
            <i class="bi bi-shield-lock display-4 text-warning mb-3"></i>
            <h4 class="fw-bold">Cybersecurity</h4>
            <p class="text-muted">Proactive threat hunting and incident response using industry-leading tools like SentinelOne.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4 text-center">
        <div class="p-4 bg-white rounded shadow-sm h-100 feature-card">
            <i class="bi bi-laptop display-4 text-warning mb-3"></i>
            <h4 class="fw-bold">IT Infrastructure</h4>
            <p class="text-muted">Expertise in network monitoring, system diagnostics, and OS management across Windows and Linux.</p>
        </div>
    </div>
    <div class="col-md-4 mb-4 text-center">
        <div class="p-4 bg-white rounded shadow-sm h-100 feature-card">
            <i class="bi bi-browser-chrome display-4 text-warning mb-3"></i>
            <h4 class="fw-bold">Web UI Dev</h4>
            <p class="text-muted">Designing and implementing complex, responsive front-end user interfaces using modern web technologies.</p>
        </div>
    </div>
</div>

<style>
    .hero-section {
        background: linear-gradient(135deg, #ffffff 0%, #f8f9fa 100%);
        border: 1px solid #eee;
        overflow: hidden;
    }
    .profile-img-container {
        width: 280px;
        height: 280px;
        border-radius: 50%;
        overflow: hidden;
        border: 8px solid #fff;
        background-color: #f39c12;
    }
    .profile-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
    }
    .text-warning {
        color: #f39c12 !important;
    }
    .btn-warning {
        background-color: #f39c12;
        border-color: #f39c12;
        color: white;
    }
    .btn-warning:hover {
        background-color: #e67e22;
        border-color: #e67e22;
        color: white;
    }
    .feature-card {
        transition: transform 0.3s ease;
    }
    .feature-card:hover {
        transform: translateY(-5px);
    }

    @@media (max-width: 576px) {
        .profile-img-container {
            width: 200px;
            height: 200px;
            border-width: 5px;
        }
        .display-3 {
            font-size: 2.5rem;
        }
    }
</style>
